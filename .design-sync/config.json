{
  "projectId": "79809d81-ccbb-4adc-b3b4-667f0f03d5fa",
  "shape": "package",
  "pkg": "tunnelfiles",
  "globalName": "TunnelFiles",
  "entry": ".design-sync/.cache/ds-entry.tsx",
  "srcDir": "src/components/ui",
  "tsconfig": "tsconfig.json",
  "cssEntry": ".design-sync/.cache/ds-styles.css",
  "extraFonts": [
    "node_modules/@fontsource/inter/latin-400.css",
    "node_modules/@fontsource/inter/latin-500.css",
    "node_modules/@fontsource/inter/latin-600.css",
    "node_modules/@fontsource/jetbrains-mono/latin-400.css",
    "node_modules/@fontsource/jetbrains-mono/latin-500.css",
    "node_modules/@fontsource/jetbrains-mono/latin-600.css",
    "node_modules/@fontsource/ibm-plex-mono/latin-400.css",
    "node_modules/@fontsource/ibm-plex-mono/latin-500.css",
    "node_modules/@fontsource/ibm-plex-mono/latin-600.css"
  ],
  "runtimeFontPrefixes": ["Fira Code", "SF Mono"],
  "guidelinesGlob": [],
  "readmeHeader": ".design-sync/conventions.md",
  "buildCmd": "node .design-sync/scripts/build-css.mjs && node .design-sync/scripts/gen-entry.mjs && node .design-sync/scripts/gen-dts.mjs",
  "provider": {
    "component": "ThemeProvider",
    "props": { "defaultTheme": "dark" }
  },
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "640x460" },
    "AlertDialog": { "cardMode": "single", "viewport": "640x460" },
    "Sheet": { "cardMode": "single", "viewport": "640x460" },
    "Select": { "cardMode": "single", "viewport": "440x380" },
    "DropdownMenu": { "cardMode": "single", "viewport": "440x420" },
    "ContextMenu": { "cardMode": "single", "viewport": "460x420" },
    "Tooltip": { "cardMode": "single", "viewport": "420x240" },
    "Toaster": { "cardMode": "single", "viewport": "460x360" },
    "Table": { "cardMode": "column" },
    "Sidebar": { "cardMode": "single", "viewport": "480x440" },
    "ErrorState": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "Accordion": "src/components/ui/accordion.tsx",
    "AlertDialog": "src/components/ui/alert-dialog.tsx",
    "Badge": "src/components/ui/badge.tsx",
    "Button": "src/components/ui/button.tsx",
    "Card": "src/components/ui/card.tsx",
    "Checkbox": "src/components/ui/checkbox.tsx",
    "Collapsible": "src/components/ui/collapsible.tsx",
    "ContextMenu": "src/components/ui/context-menu.tsx",
    "Dialog": "src/components/ui/dialog.tsx",
    "DropdownMenu": "src/components/ui/dropdown-menu.tsx",
    "Empty": "src/components/ui/empty.tsx",
    "ErrorState": "src/components/ui/ErrorState.tsx",
    "Form": "src/components/ui/form.tsx",
    "Input": "src/components/ui/input.tsx",
    "Label": "src/components/ui/label.tsx",
    "LoadingSpinner": "src/components/ui/LoadingSpinner.tsx",
    "Progress": "src/components/ui/progress.tsx",
    "ResizablePanelGroup": "src/components/ui/resizable.tsx",
    "ScrollArea": "src/components/ui/scroll-area.tsx",
    "Select": "src/components/ui/select.tsx",
    "Separator": "src/components/ui/separator.tsx",
    "Sheet": "src/components/ui/sheet.tsx",
    "Sidebar": "src/components/ui/sidebar.tsx",
    "Skeleton": "src/components/ui/skeleton.tsx",
    "Slider": "src/components/ui/slider.tsx",
    "Toaster": "src/components/ui/sonner.tsx",
    "Table": "src/components/ui/table.tsx",
    "Textarea": "src/components/ui/textarea.tsx",
    "Tooltip": "src/components/ui/tooltip.tsx"
  }
}
